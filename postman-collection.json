{
  "info": {
    "name": "Fake Store API",
    "description": "Collection para testar a API Fake Store local ou em produção",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Produtos",
      "item": [
        {
          "name": "Listar todos os produtos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/products",
              "host": ["{{BASE_URL}}"],
              "path": ["products"]
            },
            "description": "Retorna um array com todos os produtos"
          }
        },
        {
          "name": "Obter um produto por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/products/1",
              "host": ["{{BASE_URL}}"],
              "path": ["products", "1"]
            },
            "description": "Retorna um único produto baseado no ID"
          }
        },
        {
          "name": "Criar novo produto",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Novo Produto\",\n  \"price\": 29.99,\n  \"description\": \"Descrição do produto\",\n  \"image\": \"https://via.placeholder.com/150\",\n  \"category\": \"electronics\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/products",
              "host": ["{{BASE_URL}}"],
              "path": ["products"]
            },
            "description": "Cria um novo produto (não persiste se usar free tier com reciclo)"
          }
        },
        {
          "name": "Atualizar produto",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Produto Atualizado\",\n  \"price\": 39.99,\n  \"description\": \"Descrição atualizada\",\n  \"image\": \"https://via.placeholder.com/150\",\n  \"category\": \"electronics\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/products/1",
              "host": ["{{BASE_URL}}"],
              "path": ["products", "1"]
            },
            "description": "Atualiza um produto existente"
          }
        },
        {
          "name": "Deletar produto",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/products/1",
              "host": ["{{BASE_URL}}"],
              "path": ["products", "1"]
            },
            "description": "Deleta um produto"
          }
        }
      ]
    },
    {
