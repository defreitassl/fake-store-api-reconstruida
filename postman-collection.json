              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"date\": \"2023-10-01\",\n  \"products\": [\n    {\n      \"productId\": 1,\n      \"quantity\": 2\n    },\n    {\n      \"productId\": 5,\n      \"quantity\": 1\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/carts",
              "host": ["{{BASE_URL}}"],
              "path": ["carts"]
            },
            "description": "Cria um novo carrinho com produtos"
          }
        }
      ]
    },
