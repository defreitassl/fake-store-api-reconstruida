# ============================================
# CONFIGURAÇÃO PARA PRODUÇÃO NO RENDER.com
# ============================================

# Porta (Render define automaticamente a variável PORT)
PORT=8765

# MongoDB - Use a string de conexão do Render
# Exemplo: mongodb+srv://usuario:senha@cluster.mongodb.net/fake_store
# ⚠️ MUDE ISSO NO RENDER.com - NÃO COMITE SENHAS!
DATABASE_URL=mongodb+srv://usuario:senha@seu-cluster.mongodb.net/fake_store?retryWrites=true&w=majority

# Banco de dados
DB_NAME=fake_store

# Se usar MongoDB Atlas (recomendado):
# DATABASE_URL=mongodb+srv://usuario:senha@seu-cluster.mongodb.net/fake_store?retryWrites=true&w=majority

# Variáveis locais (para desenvolvimento)
DB_HOST=db
DB_USERNAME=root
DB_PASSWORD=example
DB_PORT=27017

# Ambiente
NODE_ENV=production