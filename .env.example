# Copie este arquivo para .env e preencha com seus valores
# Em produção, use variáveis de ambiente do seu host (Render.com, Heroku, etc)

# Base de dados MongoDB
# LOCAL: mongodb://usuario:senha@localhost:27017/fake_store
# ATLAS: mongodb+srv://usuario:senha@cluster.mongodb.net/fake_store?retryWrites=true&w=majority
DATABASE_URL=mongodb+srv://fakestore:SENHA@seu-cluster.mongodb.net/fake_store

# Informações do BD (usado quando DATABASE_URL é local)
DB_HOST=localhost
DB_USERNAME=fakestore
DB_PASSWORD=sua_senha_aqui
DB_NAME=fake_store
DB_PORT=27017

# Porta da aplicação
PORT=8765

# Ambiente
NODE_ENV=development
